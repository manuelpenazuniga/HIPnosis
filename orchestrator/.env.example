# HIPnosis orchestrator — variables de entorno
# Copiá este archivo a .env y completá los secretos. NUNCA commitees el .env real.

# --- Modo del oráculo (real | mock | replay) ---
ORACLE_MODE=mock

# --- LLM local (vLLM con Gemma 3 27B IT) ---
LOCAL_LLM_BASE_URL=http://vllm:8000/v1
LOCAL_LLM_MODEL=google/gemma-3-27b-it

# --- LLM remoto (Fireworks; el id exacto se fija día 1) ---
REMOTE_LLM_BASE_URL=https://api.fireworks.ai/inference/v1
REMOTE_LLM_MODEL=

# --- Secretos: completar; NUNCA commitear el .env real ---
FIREWORKS_API_KEY=
HF_TOKEN=
GITHUB_TOKEN=

# --- Target GPU AMD ---
GPU_ARCH=gfx942

# --- Budgets del loop de build (INV-9: umbrales SOLO desde config) ---
MAX_ITERATIONS=25
MAX_ATTEMPTS_PER_GROUP=3
MAX_ERRORS_PARSED=30

# --- Umbral de confianza para aceptar fixes del LLM ---
CONFIDENCE_THRESHOLD=0.6

# --- Precios horarios por GPU (USD/hr) para el reporte de costo ---
PRICE_H100_HR=0.0
PRICE_MI300X_HR=0.0
